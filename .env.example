PORT=3000
MASTER_FOLDER_NAME=Auction Lot Photos

# Strongly recommended: create a Google Drive folder for this app and paste its folder ID here.
GOOGLE_DRIVE_MASTER_FOLDER_ID=

# Google OAuth credentials from Google Cloud > APIs & Services > Credentials.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Must match the Authorized redirect URI in Google Cloud.
GOOGLE_REDIRECT_URI=https://your-render-app.onrender.com/oauth2callback

# Add this after visiting /auth/google and completing the Google login.
GOOGLE_REFRESH_TOKEN=
